# =====================================================================
# Referral Code Role — environment configuration
# Copy this file to `.env` and fill in the values.
# =====================================================================

# --- Required ----------------------------------------------------------

# Postgres connection string for this plugin.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# If you're running with the bundled compose.yml, the default below works.
DATABASE_URL=postgres://app:password@db:5432/referral_code_role

# Random secret used to sign user session cookies.
# Must be EXACTLY the same value as the Auth Gateway's SESSION_SECRET,
# otherwise sign-in won't work across the two services.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=replace_me_with_a_long_random_hex_string

# Public URL where THIS plugin is reachable, including the route prefix.
# RoleLogic requires HTTPS in production. The path must end with the
# plugin slug `/referral-code-role`.
# Examples:
#   https://plugin.example.com/referral-code-role
#   https://plugins.mydomain.dev/referral-code-role
BASE_URL=https://plugin.example.com/referral-code-role

# Where the Auth Gateway lives (inside Docker, this is usually the
# service name + port). Used for sign-in checks and guild lookups.
AUTH_GATEWAY_URL=http://auth-gateway:8090

# Shared secret for internal Auth Gateway calls.
# Must match the Auth Gateway's INTERNAL_API_KEY exactly.
INTERNAL_API_KEY=replace_me_with_the_gateway_internal_key

# --- Optional ----------------------------------------------------------

# Address the HTTP server binds to inside the container.
# You almost never need to change this.
LISTEN_ADDR=0.0.0.0:8080

# How many redemption attempts a single Discord user can make per hour
# before being rate-limited. Protects against brute-force code guessing.
# 20 is a sane default; raise it if you have very short codes.
MAX_REDEEM_ATTEMPTS_PER_HOUR=20

# Postgres connection pool sizing. The defaults (min=4, max=32) are tuned
# for guilds up to a few hundred thousand members. For larger deployments
# raise max and ensure Postgres `max_connections` has the headroom.
# DATABASE_MIN_CONNECTIONS=4
# DATABASE_MAX_CONNECTIONS=32

# Logging filter. Use `debug` for verbose output while troubleshooting.
# Examples:
#   referral_code_role=info,tower_http=info   (default)
#   referral_code_role=debug                   (verbose plugin logs)
RUST_LOG=referral_code_role=info,tower_http=info
